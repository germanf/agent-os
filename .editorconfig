root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{yml,yaml}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2

[{*.ts,*.tsx,*.js,*.jsx,*.css}]
indent_size = 2

[{Makefile,*.mk}]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
